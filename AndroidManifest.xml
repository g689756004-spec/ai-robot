<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android">


    <!-- Internet access for WebSocket communication -->
    <uses-permission android:name="android.permission.INTERNET" />


    <!-- Microphone access for SpeechRecognizer -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />


    <!-- Foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />


    <!-- Android 14+ microphone foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />


    <!-- Android 14+ screen capture foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />



    <application


        android:allowBackup="true"


        android:icon="@mipmap/ic_launcher"


        android:label="AI Robot Voice Agent"


        android:roundIcon="@mipmap/ic_launcher_round"


        android:supportsRtl="true"


        android:theme="@style/Theme.AIRobot">





        <!-- Main application screen -->

        <activity

            android:name=".MainActivity"

            android:exported="true">


            <intent-filter>

                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />

            </intent-filter>


        </activity>






        <!-- Voice Recognition + Text To Speech Service -->

        <service

            android:name=".services.VoiceRecognitionService"

            android:exported="false"

            android:foregroundServiceType="microphone" />







        <!-- Screen Capture Service -->

        <service

            android:name=".services.ScreenCaptureService"

            android:exported="false"

            android:foregroundServiceType="mediaProjection" />






    </application>


</manifest>
